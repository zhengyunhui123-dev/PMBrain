# GBrain E2E 测试配置
# 复制到 .env.testing 并填写真实值
#
# 第一层（E2E 测试必需）
# 选项 A：本地 Docker Postgres（默认）
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/gbrain_test
# 选项 B：真实 Supabase 实例（测试实际生产路径）
# DATABASE_URL=postgresql://postgres.[项目引用]:[密码]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# 第二层（技能测试必需，机械测试可选）
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
